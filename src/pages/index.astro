---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWorks = (await getCollection('works'))
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));

const groupedByYear = allWorks.reduce((acc, work) => {
  const year = work.data.year;
  if (!acc[year]) acc[year] = [];
  acc[year].push(work);
  return acc;
}, {} as Record<number, typeof allWorks>);
---

<Layout title="Works | World Wide Web Commercial">
  <section class="works-section">
    {Object.entries(groupedByYear).reverse().map(([year, works]) => (
      <div class="year-group">
        <h2 class="year-title">{year}</h2>
        <div class="works-grid">
          {works.map((work) => (
            <article class="work-card">
              <a href={`/work/${work.slug}`} class="work-link">
                {work.data.images[0]?.image && (
                  <div class="work-image">
                    <img
                      src={work.data.images[0].image}
                      alt={work.data.images[0].alt || work.data.title}
                      loading="lazy"
                    />
                  </div>
                )}
                <h3 class="work-title">{work.data.title}</h3>
              </a>
            </article>
          ))}
        </div>
      </div>
    ))}
  </section>
</Layout>

<style>
  .works-section {
    padding: 3rem 0;
  }

  .year-title {
    font-size: 3rem;
    font-weight: 300;
    margin: 0 0 2rem;
    color: var(--accent);
  }

  .works-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 2rem;
    margin-bottom: 4rem;
  }

  .work-link {
    display: block;
    text-decoration: none;
    color: var(--text);
    transition: opacity 0.2s;
  }

  .work-link:hover {
    opacity: 0.8;
  }

  .work-image {
    aspect-ratio: 500/750;
    overflow: hidden;
    background: var(--border);
  }

  .work-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s;
  }

  .work-link:hover .work-image img {
    transform: scale(1.05);
  }

  .work-title {
    font-size: 1.1rem;
    font-weight: 400;
    margin: 1rem 0 0;
  }
</style>
