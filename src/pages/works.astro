---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allWorks = (await getCollection('works'))
  .sort((a, b) => b.data.year - a.data.year || a.data.title.localeCompare(b.data.title));
---

<Layout title="Works | World Wide Web Commercial">
  <div class="works-wrap">
    <div class="works-loading" id="works-loading">
      <span class="loading-dot">·</span><span class="loading-dot">·</span><span class="loading-dot">·</span>
    </div>
    <div class="works-masonry" id="works-masonry" style="opacity:0">
      {allWorks.map((work) => (
        work.data.images[0]?.image && (
          <a
            href={`/work/${work.slug}`}
            class="work-item"
            data-images={JSON.stringify(work.data.images.map(i => i.image))}
          >
            <img
              src={work.data.images[0].image}
              alt={work.data.images[0].alt || work.data.title}
              loading="lazy"
            />
          </a>
        )
      ))}
    </div>
  </div>
</Layout>

<style>
  .works-wrap {
    padding: 2rem 14rem;
  }

  .works-masonry {
    position: relative;
  }

  .work-item {
    position: absolute;
    display: block;
  }

  .work-item img {
    width: 100%;
    height: auto;
    display: block;
    transition: opacity 0.15s;
  }

  .work-item:hover img {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .works-wrap {
      padding: 2rem 4rem;
    }
  }

  @media (max-width: 600px) {
    .works-wrap {
      padding: 1rem 1.5rem;
    }
  }

  .works-masonry {
    transition: opacity 0.35s ease;
  }

  .works-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.3rem;
    height: 40vh;
    color: var(--accent);
    font-size: 2rem;
    letter-spacing: 0.2rem;
  }

  .loading-dot {
    animation: blink 1.2s infinite;
  }

  .loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .loading-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes blink {
    0%, 80%, 100% { opacity: 0.15; }
    40% { opacity: 1; }
  }
</style>

<script>
  const GAP = 8;

  function getCols() {
    return window.innerWidth <= 600 ? 2 : 3;
  }

  function runMasonry() {
    const container = document.querySelector<HTMLElement>('.works-masonry');
    if (!container) return;
    const items = Array.from(container.querySelectorAll<HTMLElement>('.work-item'));
    const cols = getCols();
    const totalWidth = container.clientWidth;
    const colWidth = (totalWidth - GAP * (cols - 1)) / cols;
    const colHeights = new Array(cols).fill(0);

    items.forEach((item) => {
      item.style.width = colWidth + 'px';
      // find shortest column
      const minH = Math.min(...colHeights);
      const col = colHeights.indexOf(minH);
      item.style.left = col * (colWidth + GAP) + 'px';
      item.style.top = colHeights[col] + 'px';
      colHeights[col] += item.offsetHeight + GAP;
    });

    container.style.height = Math.max(...colHeights) + 'px';
  }

  // Wait for all images, then layout + reveal
  function init() {
    const imgs = Array.from(document.querySelectorAll<HTMLImageElement>('.work-item img'));
    const promises = imgs.map(img =>
      img.complete ? Promise.resolve() : new Promise(r => { img.onload = r; img.onerror = r; })
    );
    Promise.all(promises).then(() => {
      runMasonry();
      const masonry = document.getElementById('works-masonry');
      const loader = document.getElementById('works-loading');
      if (loader) loader.style.display = 'none';
      if (masonry) masonry.style.opacity = '1';
    });
  }

  init();
  window.addEventListener('resize', runMasonry);

  // Hover: cycle through images
  document.querySelectorAll<HTMLAnchorElement>('.work-item').forEach((item) => {
    const images: string[] = JSON.parse(item.dataset.images || '[]');
    if (images.length <= 1) return;
    const img = item.querySelector('img') as HTMLImageElement;
    let interval: ReturnType<typeof setInterval> | null = null;
    let index = 0;

    item.addEventListener('mouseenter', () => {
      index = 0;
      interval = setInterval(() => {
        index = (index + 1) % images.length;
        img.src = images[index];
      }, 600);
    });

    item.addEventListener('mouseleave', () => {
      if (interval) clearInterval(interval);
      img.src = images[0];
    });
  });
</script>
