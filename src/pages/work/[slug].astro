---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const works = await getCollection('works');
  return works.map((work) => ({
    params: { slug: work.slug },
    props: work,
  }));
}

const work = Astro.props;
const { Content } = await work.render();
---

<Layout title={`${work.data.title} | World Wide Web Commercial`}>
  <section class="work-detail">
    <a href="/works" class="back-link">← Works</a>

    <header class="work-header">
      <h1 class="work-title">{work.data.title}</h1>
      {work.data.description && (
        <p class="work-description">{work.data.description}</p>
      )}
    </header>

    <div class="work-loading" id="work-loading">
      <span class="loading-dot">·</span><span class="loading-dot">·</span><span class="loading-dot">·</span>
    </div>

    <div class="work-images" id="work-images" style="opacity:0">
      {work.data.images.map((img) => (
        <figure class="work-image">
          <img
            src={img.image}
            alt={img.alt || work.data.title}
          />
          {img.alt && <figcaption>{img.alt}</figcaption>}
        </figure>
      ))}
    </div>

    <Content />
  </section>
</Layout>

<script>
  const imgs = Array.from(document.querySelectorAll<HTMLImageElement>('.work-image img'));
  const promises = imgs.map(img =>
    img.complete ? Promise.resolve() : new Promise(r => { img.onload = r; img.onerror = r; })
  );
  Promise.all(promises).then(() => {
    const loader = document.getElementById('work-loading');
    const images = document.getElementById('work-images');
    if (loader) loader.style.display = 'none';
    if (images) images.style.opacity = '1';
  });
</script>

<style>
  .work-detail {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 2rem 6rem;
  }

  .back-link {
    display: inline-block;
    margin-bottom: 2rem;
    color: var(--accent);
    font-size: 0.9rem;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .work-header {
    margin-bottom: 2rem;
  }

  .work-title {
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0;
    font-family: Georgia, 'Times New Roman', serif;
  }

  .work-description {
    font-size: 1rem;
    color: var(--accent);
    margin: 0.75rem 0 0;
  }

  .work-images {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    transition: opacity 0.35s ease;
  }

  .work-loading {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.3rem;
    height: 40vh;
    color: var(--accent);
    font-size: 2rem;
    letter-spacing: 0.2rem;
  }

  .loading-dot {
    animation: blink 1.2s infinite;
  }

  .loading-dot:nth-child(2) { animation-delay: 0.2s; }
  .loading-dot:nth-child(3) { animation-delay: 0.4s; }

  @keyframes blink {
    0%, 80%, 100% { opacity: 0.15; }
    40% { opacity: 1; }
  }

  .work-image {
    margin: 0;
  }

  .work-image img {
    width: 100%;
    height: auto;
  }

  figcaption {
    text-align: center;
    color: var(--accent);
    font-size: 0.85rem;
    margin-top: 0.4rem;
  }
</style>
