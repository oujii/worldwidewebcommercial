---
interface Props {
  title?: string;
}

const { title = 'Cecilia Pfaff - World Wide Web Commercial' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cecilia Pfaff - Art works 2018-2025" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fafafa" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <h1 class="site-title"><a href="/">World Wide Web Commercial</a></h1>
        <p class="site-subtitle">Cecilia Pfaff</p>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; 2025 Cecilia Pfaff</p>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #444444;
        --accent: #74828b;
        --border: #e0e0e0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Gibson, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      .container {
        max-width: 1400px;
        margin: 0 auto;
        padding: 0 2rem;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: var(--text);
        text-decoration: none;
      }

      a:hover {
        color: var(--accent);
      }
    </style>

    <style>
      .site-header {
        padding: 2rem 0;
        border-bottom: 1px solid var(--border);
      }

      .site-title {
        margin: 0;
        font-size: 2rem;
        font-weight: 400;
      }

      .site-title a {
        color: var(--text);
      }

      .site-subtitle {
        margin: 0.5rem 0 0;
        color: var(--accent);
        font-weight: 400;
      }

      main {
        min-height: calc(100vh - 300px);
      }

      .site-footer {
        padding: 2rem 0;
        border-top: 1px solid var(--border);
        text-align: center;
        color: var(--accent);
      }

      .site-footer p {
        margin: 0;
      }
    </style>
  </body>
</html>
