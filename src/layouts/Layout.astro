---
interface Props {
  title?: string;
}

const { title = 'World Wide Web Commercial' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Cecilia Pfaff - Art works 2018-2025" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#fafafa" />
    <title>{title}</title>
  </head>
  <body>
    <nav class="site-nav">
      <a href="/" class="nav-icon" title="Home">⌂</a>
      <a href="/works" class="nav-icon" title="Works">∷</a>
      <a href="/me" class="nav-icon" title="About">☺</a>
    </nav>

    <main>
      <slot />
    </main>

    <style is:global>
      :root {
        --bg: #fafafa;
        --text: #444444;
        --accent: #74828b;
        --border: #e0e0e0;
      }

      * {
        box-sizing: border-box;
      }

      body {
        margin: 0;
        font-family: Georgia, 'Times New Roman', serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }

      img {
        max-width: 100%;
        height: auto;
        display: block;
      }

      a {
        color: var(--text);
        text-decoration: none;
      }

      a:hover {
        color: var(--accent);
      }
    </style>

    <style>
      .site-nav {
        display: flex;
        justify-content: center;
        gap: 2rem;
        padding: 1.75rem 0;
      }

      .nav-icon {
        font-size: 1.6rem;
        color: var(--accent);
        text-decoration: none;
        line-height: 1;
        opacity: 0.7;
        transition: opacity 0.15s;
      }

      .nav-icon:hover {
        opacity: 1;
        color: var(--accent);
      }

      main {
        min-height: calc(100vh - 60px);
      }
    </style>
  </body>
</html>
